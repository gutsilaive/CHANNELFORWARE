# ─── Telegram Bot (from @BotFather) ──────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Admin Telegram User ID (only this user can access the bot) ───────────────
# Get yours from @userinfobot
ADMIN_ID=123456789

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# ─── Render Keep-Alive (Optional) ─────────────────────────────────────────────
# If running on Render as a "Web Service", Render sets this automatically!
# If running locally or as a Background Worker, set this to your Render app URL:
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com
